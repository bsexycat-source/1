# card.py
import pygame
from constants import *

class Card:
    def __init__(self, suit, rank, face_up=False):
        self.suit = suit
        self.rank = rank
        self.face_up = face_up
        self.value = RANK_VALUES[rank]
        self.color = SUIT_COLORS[suit]
        self.rect = pygame.Rect(0, 0, CARD_WIDTH, CARD_HEIGHT)
        
    def __repr__(self):
        return f"{self.rank}{self.suit}"
    
    def flip(self):
        """Flip the card (turn face up/down)"""
        self.face_up = not self.face_up
        return self
    
    def is_red(self):
        return self.color == RED
    
    def is_black(self):
        return self.color == BLACK
    
    def can_place_on_tableau(self, other):
        """Check if this card can be placed on another card in tableau"""
        if not other or not other.face_up:
            return False
        return (self.color != other.color and 
                self.value == other.value - 1)
    
    def can_place_on_foundation(self, other):
        """Check if this card can be placed on foundation"""
        if not other:
            return self.rank == 'A'
        return (self.suit == other.suit and 
                self.value == other.value + 1)
    
    def draw(self, screen, x, y, scale=1.0):
        """Draw the card on screen"""
        width = int(CARD_WIDTH * scale)
        height = int(CARD_HEIGHT * scale)
        rect = pygame.Rect(x, y, width, height)
        
        if not self.face_up:
            # Draw card back
            pygame.draw.rect(screen, BLUE, rect, border_radius=CARD_RADIUS)
            pygame.draw.rect(screen, BLACK, rect, 2, border_radius=CARD_RADIUS)
            # Pattern on card back
            for i in range(3):
                for j in range(3):
                    center_x = x + width // 6 + i * (width // 3)
                    center_y = y + height // 6 + j * (height // 3)
                    pygame.draw.circle(screen, GOLD, (center_x, center_y), 8)
            return rect
        
        # Draw face up card
        pygame.draw.rect(screen, WHITE, rect, border_radius=CARD_RADIUS)
        pygame.draw.rect(screen, BLACK, rect, 2, border_radius=CARD_RADIUS)
        
        # Draw rank and suit
        font_size = int(20 * scale)
        font = pygame.font.Font(None, font_size)
        
        # Top-left
        rank_text = font.render(self.rank, True, self.color)
        screen.blit(rank_text, (x + 5, y + 3))
        suit_text = font.render(self.suit, True, self.color)
        screen.blit(suit_text, (x + 5, y + 3 + font_size))
        
        # Center (large suit)
        center_font = pygame.font.Font(None, int(40 * scale))
        suit_center = center_font.render(self.suit, True, self.color)
        center_x = x + width // 2 - suit_center.get_width() // 2
        center_y = y + height // 2 - suit_center.get_height() // 2
        screen.blit(suit_center, (center_x, center_y))
        
        # Bottom-right (rotated)
        rank_text_bottom = font.render(self.rank, True, self.color)
        suit_text_bottom = font.render(self.suit, True, self.color)
        screen.blit(rank_text_bottom, (x + width - 5 - rank_text_bottom.get_width(), 
                                       y + height - 3 - font_size - suit_text_bottom.get_height()))
        screen.blit(suit_text_bottom, (x + width - 5 - suit_text_bottom.get_width(), 
                                       y + height - 3 - font_size))
        
        return rect
