# main.py
import pygame
import sys
from constants import *
from game import SolitaireGame

class SolitaireApp:
    def __init__(self):
        pygame.init()
        self.screen = pygame.display.set_mode((WINDOW_WIDTH, WINDOW_HEIGHT))
        pygame.display.set_caption("Klondike Solitaire")
        self.clock = pygame.time.Clock()
        self.font = pygame.font.Font(None, 36)
        
        self.game = SolitaireGame()
        self.dragging = False
        self.drag_cards = []
        self.drag_source = None
        self.drag_offset = (0, 0)
        self.drag_start = (0, 0)
        
        self.message = ""
        self.message_timer = 0
        
    def draw(self):
        """Draw everything on screen"""
        self.screen.fill(DARK_GREEN)
        
        # Draw stock pile
        stock_x = LEFT_OFFSET
        stock_y = TOP_OFFSET
        if self.game.stock:
            # Draw card back
            temp_card = Card('♠', 'A', False)
            temp_card.draw(self.screen, stock_x, stock_y)
        else:
            # Empty stock indicator
            pygame.draw.rect(self.screen, (50, 50, 50), 
                           (stock_x, stock_y, CARD_WIDTH, CARD_HEIGHT), 2)
            # Draw reset icon
            text = self.font.render("↻", True, WHITE)
            self.screen.blit(text, (stock_x + CARD_WIDTH//2 - text.get_width()//2,
                                   stock_y + CARD_HEIGHT//2 - text.get_height()//2))
        
        # Draw waste pile
        waste_x = LEFT_OFFSET + CARD_WIDTH + CARD_PADDING
        waste_y = TOP_OFFSET
        if self.game.waste:
            self.game.waste[-1].draw(self.screen, waste_x, waste_y)
        else:
            pygame.draw.rect(self.screen, (50, 50, 50), 
                           (waste_x, waste_y, CARD_WIDTH, CARD_HEIGHT), 2)
        
        # Draw foundations
        for i in range(4):
            fx, fy = self.game.get_foundation_position(i)
            if self.game.foundations[i]:
                self.game.foundations[i][-1].draw(self.screen, fx, fy)
            else:
                pygame.draw.rect(self.screen, (50, 50, 50), 
                               (fx, fy, CARD_WIDTH, CARD_HEIGHT), 2)
                # Show suit placeholder
                suit_font = pygame.font.Font(None, 24)
                suit_text = suit_font.render(SUITS[i], True, (100, 100, 100))
                self.screen.blit(suit_text, (fx + CARD_WIDTH//2 - suit_text.get_width()//2,
                                            fy + CARD_HEIGHT//2 - suit_text.get_height()//2))
        
        # Draw tableau
        for col in range(7):
            cards = self.game.tableau[col]
            if not cards:
                # Empty slot indicator
                x = LEFT_OFFSET + col * (CARD_WIDTH + CARD_PADDING)
                y = TOP_OFFSET
                pygame.draw.rect(self.screen, (50, 50, 50), 
                               (x, y, CARD_WIDTH, CARD_HEIGHT), 2)
                continue
            
            for i, card in enumerate(cards):
                x = LEFT_OFFSET + col * (CARD_WIDTH + CARD_PADDING)
                y = TOP_OFFSET + i * STACK_VERTICAL_OFFSET
                
                # If card is being dragged, skip drawing it here
                if self.dragging and card in self.drag_cards:
                    continue
                
                card.draw(self.screen, x, y)
        
        # Draw dragged cards
        if self.dragging and self.drag_cards:
            mouse_x, mouse_y = pygame.mouse.get_pos()
            offset_x, offset_y = self.drag_offset
            
            for i, card in enumerate(self.drag_cards):
                x = mouse_x - offset_x
                y = mouse_y - offset_y + i * STACK_VERTICAL_OFFSET
                card.draw(self.screen, x, y)
        
        # Draw message
        if self.message and self.message_timer > 0:
            text = self.font.render(self.message, True, GOLD)
            text_rect = text.get_rect(center=(WINDOW_WIDTH//2, WINDOW_HEIGHT - 50))
            # Background for message
            pygame.draw.rect(self.screen, (0, 0, 0, 150), 
                           (text_rect.x - 10, text_rect.y - 10,
                            text_rect.width + 20, text_rect.height + 20))
            self.screen.blit(text, text_rect)
            self.message_timer -= 1
        
        # Draw game info
        info_font = pygame.font.Font(None, 24)
        stock_count = info_font.render(f"Stock: {len(self.game.stock)}", True, WHITE)
        self.screen.blit(stock_count, (LEFT_OFFSET, TOP_OFFSET + CARD_HEIGHT + 10))
        
        waste_count = info_font.render(f"Waste: {len(self.game.waste)}", True, WHITE)
        self.screen.blit(waste_count, (LEFT_OFFSET + CARD_WIDTH + CARD_PADDING, 
                                      TOP_OFFSET + CARD_HEIGHT + 10))
        
        # Win message
        if self.game.is_game_won():
            win_text = pygame.font.Font(None, 72).render("YOU WIN!", True, GOLD)
            win_rect = win_text.get_rect(center=(WINDOW_WIDTH//2, WINDOW_HEIGHT//2))
            # Background
            pygame.draw.rect(self.screen, (0, 0, 0, 200), 
                           (win_rect.x - 20, win_rect.y - 20,
                            win_rect.width + 40, win_rect.height + 40))
            self.screen.blit(win_text, win_rect)
        
        pygame.display.flip()
    
    def handle_click(self, pos):
        """Handle mouse click events"""
        x, y = pos
        
        # Check if clicking on stock
        if self.game.click_stock(x, y):
            return
        
        # Check if clicking on waste
        waste_result = self.game.click_waste(x, y)
        if waste_result:
            source, index, card = waste_result
            # Try to move to foundation
            foundation_index = SUITS.index(card.suit)
            if self.game.can_move_to_foundation(card, foundation_index):
                if self.game.move_to_foundation(card, 'waste', None):
                    self.show_message("Moved to foundation!")
                    self.check_auto_complete()
                    return
            
            # Try to move to tableau (if it's a valid move)
            for col in range(7):
                if self.game.can_move_to_tableau([card], col):
                    self.game.waste.pop()
                    self.game.tableau[col].append(card)
                    self.show_message("Moved to tableau!")
                    return
            
            # If can't move, just select the card for drag
            self.drag_cards = [card]
            self.drag_source = ('waste', None)
            self.drag_offset = (x - (LEFT_OFFSET + CARD_WIDTH + CARD_PADDING), 
                               y - TOP_OFFSET)
            self.dragging = True
            return
        
        # Check tableau
        result = self.game.get_clicked_card(x, y)
        if result and result[0] == 'tableau':
            source, col, cards = result
            # Check if we can drag a sequence
            if isinstance(cards, list) and cards and cards[0].face_up:
                self.drag_cards = cards
                self.drag_source = ('tableau', col)
                # Calculate offset
                first_card_x = LEFT_OFFSET + col * (CARD_WIDTH + CARD_PADDING)
                card_index = self.game.tableau[col].index(cards[0])
                first_card_y = TOP_OFFSET + card_index * STACK_VERTICAL_OFFSET
                self.drag_offset = (x - first_card_x, y - first_card_y)
                self.dragging = True
            return
        
        # Check foundation
        foundation_result = self.game.click_foundation(x, y)
        if foundation_result:
            source, index, card = foundation_result
            # Can't drag from foundation in standard solitaire
            return
        
        # Click on empty tableau slot - try to move from waste or selected cards
        for col in range(7):
            x_pos = LEFT_OFFSET + col * (CARD_WIDTH + CARD_PADDING)
            y_pos = TOP_OFFSET
            rect = pygame.Rect(x_pos, y_pos, CARD_WIDTH, CARD_HEIGHT)
            if rect.collidepoint(x, y):
                if not self.game.tableau[col]:
                    # Try to move from waste to empty tableau
                    if self.game.waste and self.game.waste[-1].rank == 'K':
                        card = self.game.waste.pop()
                        self.game.tableau[col].append(card)
                        self.show_message("Moved King to empty tableau!")
                        return
                    
                    # Try to move from selected cards
                    if self.dragging and self.drag_cards:
                        if self.drag_cards[0].rank == 'K':
                            source, src_col = self.drag_source
                            if source == 'tableau':
                                if self.game.move_to_tableau(self.drag_cards, src_col, col):
                                    self.dragging = False
                                    self.drag_cards = []
                                    self.show_message("Moved to empty tableau!")
                                    self.check_auto_complete()
                                    return
        
        # If clicked on empty space, cancel drag
        self.dragging = False
        self.drag_cards = []
    
    def handle_drag_drop(self):
        """Handle dropping dragged cards"""
        if not self.dragging or not self.drag_cards:
            return
        
        x, y = pygame.mouse.get_pos()
        source, src_col = self.drag_source
        
        # Check if dropping on tableau
        for col in range(7):
            x_pos = LEFT_OFFSET + col * (CARD_WIDTH + CARD_PADDING)
            # Check if the drop is over a card or empty slot
            cards = self.game.tableau[col]
            if cards:
                # Check if over the top card
                top_card = cards[-1]
                if top_card.face_up:
                    card_x = x_pos
                    card_y = TOP_OFFSET + (len(cards) - 1) * STACK_VERTICAL_OFFSET
                    rect = pygame.Rect(card_x, card_y, CARD_WIDTH, CARD_HEIGHT)
                    if rect.collidepoint(x, y):
                        if self.game.can_move_to_tableau(self.drag_cards, col):
                            if source == 'tableau':
                                if self.game.move_to_tableau(self.drag_cards, src_col, col):
                                    self.dragging = False
                                    self.drag_cards = []
                                    self.show_message("Moved to tableau!")
                                    self.check_auto_complete()
                                    return
            else:
                # Empty column - check if dropping on it
                rect = pygame.Rect(x_pos, TOP_OFFSET, CARD_WIDTH, CARD_HEIGHT)
                if rect.collidepoint(x, y) and self.drag_cards[0].rank == 'K':
                    if source == 'tableau':
                        if self.game.move_to_tableau(self.drag_cards, src_col, col):
                            self.dragging = False
                            self.drag_cards = []
                            self.show_message("Moved to empty tableau!")
                            self.check_auto_complete()
                            return
        
        # Check if dropping on foundation
        for i in range(4):
            fx, fy = self.game.get_foundation_position(i)
            rect = pygame.Rect(fx, fy, CARD_WIDTH, CARD_HEIGHT)
            if rect.collidepoint(x, y) and len(self.drag_cards) == 1:
                card = self.drag_cards[0]
                foundation_index = SUITS.index(card.suit)
                if self.game.can_move_to_foundation(card, foundation_index):
                    if source == 'tableau':
                        if self.game.move_to_foundation(card, 'tableau', src_col):
                            self.dragging = False
                            self.drag_cards = []
                            self.show_message("Moved to foundation!")
                            self.check_auto_complete()
                            return
                    elif source == 'waste':
                        if self.game.move_to_foundation(card, 'waste', None):
                            self.dragging = False
                            self.drag_cards = []
                            self.show_message("Moved to foundation!")
                            self.check_auto_complete()
                            return
        
        # If dropped in invalid location, cancel drag
        self.dragging = False
        self.drag_cards = []
    
    def check_auto_complete(self):
        """Check if we can auto-complete the game"""
        if self.game.auto_complete():
            self.show_message("Auto-completed!")
    
    def show_message(self, text):
        """Show a message on screen"""
        self.message = text
        self.message_timer = 120  # Show for 2 seconds at 60 FPS
    
    def run(self):
        """Main game loop"""
        running = True
        
        while running:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
                
                elif event.type == pygame.MOUSEBUTTONDOWN:
                    if event.button == 1:  # Left click
                        # If dragging, drop the cards
                        if self.dragging:
                            self.handle_drag_drop()
                        else:
                            self.handle_click(event.pos)
                    
                    elif event.button == 3:  # Right click
                        # Auto-move a card to foundation if possible
                        # Check waste
                        if self.game.waste:
                            card = self.game.waste[-1]
                            foundation_index = SUITS.index(card.suit)
                            if self.game.can_move_to_foundation(card, foundation_index):
                                self.game.move_to_foundation(card, 'waste', None)
                                self.show_message("Moved to foundation!")
                                self.check_auto_complete()
                                continue
                        
                        # Check tableau
                        for col in range(7):
                            if self.game.tableau[col]:
                                card = self.game.tableau[col][-1]
                                if card.face_up:
                                    foundation_index = SUITS.index(card.suit)
                                    if self.game.can_move_to_foundation(card, foundation_index):
                                        self.game.move_to_foundation(card, 'tableau', col)
                                        self.show_message("Moved to foundation!")
                                        self.check_auto_complete()
                                        break
                
                elif event.type == pygame.MOUSEMOTION:
                    # Update drag position if dragging
                    if self.dragging:
                        pass  # Handled in draw
                
                elif event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_r:
                        # Restart game
                        self.game = SolitaireGame()
                        self.dragging = False
                        self.drag_cards = []
                        self.show_message("New game!")
                    
                    elif event.key == pygame.K_a:
                        # Auto-complete
                        if self.game.auto_complete():
                            self.show_message("Auto-completed!")
                    
                    elif event.key == pygame.K_SPACE:
                        # Draw from stock
                        self.game.click_stock(0, 0)  # Dummy position
            
            self.draw()
            self.clock.tick(FPS)
        
        pygame.quit()
        sys.exit()

