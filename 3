# game.py
import random
import pygame
from constants import *
from card import Card

class SolitaireGame:
    def __init__(self):
        self.deck = []
        self.tableau = [[] for _ in range(7)]  # 7 columns
        self.foundations = [[] for _ in range(4)]  # 4 suits
        self.stock = []  # Draw pile
        self.waste = []  # Discard pile
        self.selected_cards = []
        self.selected_from = None
        self.dragging = False
        self.drag_offset = (0, 0)
        
        self._init_game()
        
    def _init_game(self):
        """Initialize a new game"""
        # Create deck
        self.deck = []
        for suit in SUITS:
            for rank in RANKS:
                self.deck.append(Card(suit, rank))
        
        # Shuffle
        random.shuffle(self.deck)
        
        # Deal cards to tableau
        for col in range(7):
            for row in range(col + 1):
                card = self.deck.pop()
                if row == col:
                    card.face_up = True
                self.tableau[col].append(card)
        
        # Remaining cards go to stock
        self.stock = self.deck
        self.waste = []
        self.foundations = [[] for _ in range(4)]
        self.selected_cards = []
        self.selected_from = None
        
    def get_card_at_tableau(self, x, y):
        """Get card at tableau position"""
        for col in range(7):
            cards = self.tableau[col]
            if not cards:
                continue
            
            # Calculate positions
            for i, card in enumerate(cards):
                card_x = LEFT_OFFSET + col * (CARD_WIDTH + CARD_PADDING)
                card_y = TOP_OFFSET + i * STACK_VERTICAL_OFFSET
                
                if card.face_up:
                    rect = pygame.Rect(card_x, card_y, CARD_WIDTH, CARD_HEIGHT)
                    if rect.collidepoint(x, y):
                        return (col, i, card)
                else:
                    # Only clickable if it's the top face-down card
                    if i == len(cards) - 1:
                        rect = pygame.Rect(card_x, card_y, CARD_WIDTH, CARD_HEIGHT)
                        if rect.collidepoint(x, y):
                            return (col, i, card)
        
        return None
    
    def get_tableau_position(self, col):
        """Get the position of a tableau column"""
        x = LEFT_OFFSET + col * (CARD_WIDTH + CARD_PADDING)
        if self.tableau[col]:
            y = TOP_OFFSET + (len(self.tableau[col]) - 1) * STACK_VERTICAL_OFFSET
        else:
            y = TOP_OFFSET
        return (x, y)
    
    def get_foundation_position(self, index):
        """Get the position of a foundation pile"""
        x = LEFT_OFFSET + FOUNDATION_OFFSET + index * (CARD_WIDTH + CARD_PADDING)
        y = TOP_OFFSET
        return (x, y)
    
    def click_stock(self, x, y):
        """Handle click on stock pile"""
        stock_x = LEFT_OFFSET
        stock_y = TOP_OFFSET
        
        # Check if clicking on stock
        rect = pygame.Rect(stock_x, stock_y, CARD_WIDTH, CARD_HEIGHT)
        if rect.collidepoint(x, y):
            if self.stock:
                # Draw 3 cards from stock
                for _ in range(min(3, len(self.stock))):
                    card = self.stock.pop()
                    card.face_up = True
                    self.waste.append(card)
                return True
            else:
                # Reset stock from waste
                if self.waste:
                    self.stock = self.waste[::-1]
                    for card in self.stock:
                        card.face_up = False
                    self.waste = []
                    return True
        return False
    
    def click_waste(self, x, y):
        """Handle click on waste pile"""
        if not self.waste:
            return None
        
        waste_x = LEFT_OFFSET + CARD_WIDTH + CARD_PADDING
        waste_y = TOP_OFFSET
        
        rect = pygame.Rect(waste_x, waste_y, CARD_WIDTH, CARD_HEIGHT)
        if rect.collidepoint(x, y):
            # Click on top card of waste
            card = self.waste[-1]
            return ('waste', len(self.waste) - 1, card)
        return None
    
    def click_foundation(self, x, y):
        """Handle click on foundation piles"""
        for i in range(4):
            fx, fy = self.get_foundation_position(i)
            rect = pygame.Rect(fx, fy, CARD_WIDTH, CARD_HEIGHT)
            if rect.collidepoint(x, y):
                if self.foundations[i]:
                    card = self.foundations[i][-1]
                    return ('foundation', i, card)
        return None
    
    def get_clicked_card(self, x, y):
        """Get the card clicked at position"""
        # Check stock
        if self.click_stock(x, y):
            return ('stock', None, None)
        
        # Check waste
        waste_result = self.click_waste(x, y)
        if waste_result:
            return waste_result
        
        # Check tableau
        tableau_result = self.get_card_at_tableau(x, y)
        if tableau_result:
            col, index, card = tableau_result
            # Check if we can select a sequence of face-up cards
            cards_above = self.tableau[col][index:]
            if all(c.face_up for c in cards_above):
                return ('tableau', col, cards_above)
        
        # Check foundation
        foundation_result = self.click_foundation(x, y)
        if foundation_result:
            return foundation_result
        
        return None
    
    def can_move_to_tableau(self, cards, target_col):
        """Check if cards can be moved to tableau column"""
        if not cards:
            return False
        
        target = self.tableau[target_col]
        
        # If target column is empty, only Kings can be placed
        if not target:
            return cards[0].rank == 'K'
        
        # Check if top card of target is face up
        top_card = target[-1]
        if not top_card.face_up:
            return False
        
        # Check color and value rules
        return cards[0].can_place_on_tableau(top_card)
    
    def can_move_to_foundation(self, card, foundation_index):
        """Check if card can be moved to foundation"""
        if not card:
            return False
        
        foundation = self.foundations[foundation_index]
        
        # Check suit match
        expected_suit = SUITS[foundation_index]
        if card.suit != expected_suit:
            return False
        
        # Check if foundation is empty (only Aces)
        if not foundation:
            return card.rank == 'A'
        
        top_card = foundation[-1]
        return card.can_place_on_foundation(top_card)
    
    def move_to_tableau(self, cards, source_col, target_col):
        """Move cards from source to target tableau column"""
        if not self.can_move_to_tableau(cards, target_col):
            return False
        
        # Remove from source
        source = self.tableau[source_col]
        card_index = source.index(cards[0])
        
        # Remove cards from source
        moved_cards = source[card_index:]
        del source[card_index:]
        
        # Add to target
        self.tableau[target_col].extend(moved_cards)
        
        # Flip the new top card if needed
        if source and not source[-1].face_up:
            source[-1].flip()
        
        return True
    
    def move_to_foundation(self, card, source, source_index):
        """Move a card to foundation"""
        foundation_index = SUITS.index(card.suit)
        
        if not self.can_move_to_foundation(card, foundation_index):
            return False
        
        # Remove from source
        if source == 'tableau':
            col = source_index
            source_list = self.tableau[col]
            if source_list[-1] != card:
                return False
            source_list.pop()
            # Flip new top card if needed
            if source_list and not source_list[-1].face_up:
                source_list[-1].flip()
        elif source == 'waste':
            if self.waste[-1] != card:
                return False
            self.waste.pop()
        else:
            return False
        
        # Add to foundation
        self.foundations[foundation_index].append(card)
        return True
    
    def move_from_waste_to_tableau(self, target_col):
        """Move top card from waste to tableau"""
        if not self.waste:
            return False
        
        card = self.waste[-1]
        cards = [card]
        
        if self.can_move_to_tableau(cards, target_col):
            self.waste.pop()
            self.tableau[target_col].append(card)
            return True
        return False
    
    def is_game_won(self):
        """Check if the game is won"""
        return all(len(pile) == 13 for pile in self.foundations)
    
    def auto_complete(self):
        """Auto-complete the game if possible"""
        moved = True
        while moved:
            moved = False
            # Try to move from tableau to foundation
            for col in range(7):
                if self.tableau[col]:
                    card = self.tableau[col][-1]
                    if card.face_up:
                        foundation_index = SUITS.index(card.suit)
                        if self.can_move_to_foundation(card, foundation_index):
                            self.tableau[col].pop()
                            self.foundations[foundation_index].append(card)
                            if self.tableau[col] and not self.tableau[col][-1].face_up:
                                self.tableau[col][-1].flip()
                            moved = True
                            break
            
            # Try to move from waste to foundation
            if not moved and self.waste:
                card = self.waste[-1]
                foundation_index = SUITS.index(card.suit)
                if self.can_move_to_foundation(card, foundation_index):
                    self.waste.pop()
                    self.foundations[foundation_index].append(card)
                    moved = True
        
        return self.is_game_won()
